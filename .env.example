# LLM (OpenAI-compatible)
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus

# Text model (Doubao / SiliconFlow)
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-2-0-pro-260215
DOUBAO_VL_MODEL=doubao-seed-2-0-pro-260215
DISABLE_SILICONFLOW=0

# Image model (Gemini)
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_BASE_URL=https://api.viviai.cc
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# App version (for update check UI)
APP_VERSION=1.0.0
LICENSE_PRODUCT=takealot-autolister

# Optional browser profile for persistent login state
BROWSER_USER_DATA_DIR=
BROWSER_CHANNEL=msedge
BROWSER_PROFILE_DIRECTORY=Default
STORAGE_STATE_1688=.runtime/auth/1688.json
STORAGE_STATE_TAKEALOT=.runtime/auth/takealot.json

# Pipeline defaults
DEFAULT_PORTAL_MODE=draft
DEFAULT_HEADLESS=true

# Alibaba Cloud OSS (for image hosting — required for Takealot loadsheet upload)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# Public access URL for the bucket (leave blank to auto-derive from BUCKET + ENDPOINT)
OSS_BASE_URL=
# Path prefix inside the bucket
OSS_PREFIX=takealot/images/

# Auto update manifest (served from OSS public URL)
# If AUTO_UPDATE_MANIFEST_URL is set, it has highest priority.
AUTO_UPDATE_MANIFEST_URL=
AUTO_UPDATE_MANIFEST_KEY=takealot/updates/update_manifest.json
