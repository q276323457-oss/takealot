{
    "$schema": "https://schema.freqtrade.io/schema.json",
    "bot_name": "okx-river-trend-v2",
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "liquidation_buffer": 0.05,
    "max_open_trades": 1,
    "stake_currency": "USDT",
    "stake_amount": 100,
    "tradable_balance_ratio": 0.9,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 1000,
    "timeframe": "5m",
    "cancel_open_orders_on_exit": true,
    "unfilledtimeout": {
        "entry": 20,
        "exit": 20,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "other",
        "use_order_book": false
    },
    "exit_pricing": {
        "price_side": "other",
        "use_order_book": false
    },
    "exchange": {
        "name": "okx",
        "key": "",
        "secret": "",
        "password": "",
        "ccxt_config": {
            "options": {
                "defaultType": "swap"
            }
        },
        "ccxt_async_config": {
            "options": {
                "defaultType": "swap"
            }
        },
        "pair_whitelist": [
            "RIVER/USDT:USDT"
        ],
        "pair_blacklist": []
    },
    "pairlists": [
        {
            "method": "StaticPairList"
        }
    ],
    "force_entry_enable": false,
    "initial_state": "running",
    "internals": {
        "process_throttle_secs": 5
    }
}
